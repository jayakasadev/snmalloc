common --enable_platform_specific_config

build --cxxopt=-std=c++2a

# Show everything when running tests.
test --test_output=streamed

build:macos --macos_minimum_os=10.15
build:macos --no@fuzztest//fuzztest:use_riegeli

# rules_rust_bindgen pulls in an LLVM source tree whose BUILD.bazel uses
# empty globs; tolerate those so the bindgen toolchain analyses cleanly
# on Bazel 8.x where the incompatible-disallow-empty-glob default is on.
build --incompatible_disallow_empty_glob=false

# Rust integration tests (rust_test) print to stderr; keep the output
# from being suppressed so failures are diagnosable in CI.
test --test_output=errors

try-import %workspace%/fuzztest.bazelrc
